# Gateway auth for clients calling this starter. Leave blank for local demos.
GATEWAY_API_KEY=

# Any OpenAI-compatible upstream base URL, without a trailing slash.
# Portable examples:
# UPSTREAM_BASE_URL=https://api.openai.com
# UPSTREAM_BASE_URL=https://openrouter.ai/api
#
# Disclosed example endpoint:
# UPSTREAM_BASE_URL=https://www.tken.shop/v1
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=

DEFAULT_MODEL=gateway-example-model
REQUEST_TIMEOUT_SECONDS=60
CORS_ALLOW_ORIGINS=*
